# ============================================
# HarvestPro NZ — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to git.
# ============================================

# === REQUIRED ===
# Supabase project URL & anon key (from supabase.com dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your_anon_key_here

# === OPTIONAL ===
# Gemini API key for AI features (optional)
VITE_GEMINI_API_KEY=

# App version (auto-set by CI/CD)
VITE_APP_VERSION=9.3.0

# Analytics toggle (true/false)
VITE_ENABLE_ANALYTICS=false

# Log level: debug | info | warn | error
VITE_LOG_LEVEL=info

# === PUSH NOTIFICATIONS ===
# VAPID keys for Web Push (generate with: npx web-push generate-vapid-keys --json)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
# Private key goes to Supabase secrets, NOT here:
#   supabase secrets set VAPID_PRIVATE_KEY="your_private_key"
#   supabase secrets set VAPID_PUBLIC_KEY="your_public_key"
#   supabase secrets set VAPID_SUBJECT="mailto:admin@harvestpro.nz"
